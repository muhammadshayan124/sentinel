# Copy this file to .env and fill in real values. Never commit .env itself (already gitignored).

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to "ollama" to run fully offline against a local model instead of Anthropic.
SENTINEL_LLM_BACKEND=anthropic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

SENTINEL_DATA_DIR=./data
SENTINEL_CHROMA_DIR=./chroma_data
